{
	"security.workspace.trust.enabled": false,
	"workbench.colorTheme": "GitHub Dark",
	"workbench.startupEditor": "none",
	"files.autoSave": "afterDelay",
	"files.insertFinalNewline": true,
	"explorer.confirmDelete": false,
	"explorer.confirmDragAndDrop": false,
	"editor.fontSize": 14,
	"editor.insertSpaces": false,
	"editor.minimap.enabled": false,
	"terminal.integrated.defaultProfile.windows": "Command Prompt",
	"terminal.integrated.enableMultiLinePasteWarning": "never",
	// "C_Cpp.default.compilerPath": "C:\\mingw64\\bin\\g++.exe",
	"C_Cpp.default.cppStandard": "gnu++14",
	"code-runner.ignoreSelection": true,
	"code-runner.runInTerminal": true,
	"code-runner.saveFileBeforeRun": true,
	"print.editorTitleMenuButtonPreview": false,
	"print.editorTitleMenuButtonPrint": false,
	"code-runner.executorMap": {
		"cpp": "cd $dir && g++ \"$fileName\" -std=c++14 -Wall -Wextra -Wl,--stack=2147483647 -o \"$fileNameWithoutExt\" && \"$fileNameWithoutExt\" && del \"$fileNameWithoutExt.exe\"",
	},
	"git.confirmSync": false,
	"git.decorations.enabled": false,
	"git.enableSmartCommit": true,
	"files.associations": {
		"*.tcc": "cpp",
		"list": "cpp",
		"chrono": "cpp",
		"iostream": "cpp",
		"tuple": "cpp",
		"utility": "cpp",
		"bitset": "cpp",
		"string_view": "cpp",
		"array": "cpp",
		"atomic": "cpp",
		"cctype": "cpp",
		"cfenv": "cpp",
		"cinttypes": "cpp",
		"clocale": "cpp",
		"cmath": "cpp",
		"complex": "cpp",
		"condition_variable": "cpp",
		"csetjmp": "cpp",
		"csignal": "cpp",
		"cstdarg": "cpp",
		"cstddef": "cpp",
		"cstdint": "cpp",
		"cstdio": "cpp",
		"cstdlib": "cpp",
		"cstring": "cpp",
		"ctime": "cpp",
		"cwchar": "cpp",
		"cwctype": "cpp",
		"deque": "cpp",
		"forward_list": "cpp",
		"unordered_map": "cpp",
		"unordered_set": "cpp",
		"vector": "cpp",
		"exception": "cpp",
		"fstream": "cpp",
		"functional": "cpp",
		"future": "cpp",
		"initializer_list": "cpp",
		"iomanip": "cpp",
		"iosfwd": "cpp",
		"istream": "cpp",
		"limits": "cpp",
		"mutex": "cpp",
		"new": "cpp",
		"ostream": "cpp",
		"numeric": "cpp",
		"ratio": "cpp",
		"scoped_allocator": "cpp",
		"sstream": "cpp",
		"stdexcept": "cpp",
		"streambuf": "cpp",
		"system_error": "cpp",
		"thread": "cpp",
		"regex": "cpp",
		"type_traits": "cpp",
		"typeindex": "cpp",
		"typeinfo": "cpp",
		"valarray": "cpp"
	},
}
